<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
		<meta name="description" content="{{ description or site.tagline }}" />
		<link rel="icon" href="{{ '/favicon.svg' | relUrl(page.url) }}" type="image/svg+xml" />

		<link rel="stylesheet" href="{{ '/assets/css/tokens.css' | relUrl(page.url) }}" />
		<link rel="stylesheet" href="{{ '/assets/css/base.css' | relUrl(page.url) }}" />
		<link rel="stylesheet" href="{{ '/assets/css/layout.css' | relUrl(page.url) }}" />
		{% if playground %}
			<link rel="stylesheet" href="{{ '/assets/css/playground.css' | relUrl(page.url) }}" />
		{% endif %}
		<link rel="stylesheet" href="{{ '/assets/css/prism.css' | relUrl(page.url) }}" />

		<script>
			// Apply theme synchronously to avoid flash
			(function () {
				try {
					var t = localStorage.getItem("swatch-theme");
					if (!t) {
						t = window.matchMedia("(prefers-color-scheme: dark)").matches
							? "dark"
							: "light";
					}
					document.documentElement.dataset.theme = t;
				} catch (e) {}
			})();
		</script>
	</head>
	<body>
		<a href="#main" class="skip-link">Skip to content</a>

		<header class="site-header">
			<div class="site-header__bar">
			<div class="brand-lockup">
				{% if playground %}
					<label class="header-color" data-header-color-chip title="Pick playground color">
						<span class="visually-hidden">Pick playground color</span>
						<input
							id="header-color-picker"
							type="color"
							data-header-color-picker
							aria-label="Pick playground color"
						/>
					</label>
				{% endif %}
				<a class="wordmark" href="{{ '/' | relUrl(page.url) }}" aria-label="Swatch home">
					<span class="wordmark__name">Swatch</span>
					<span class="wordmark__version">{{ site.version }}</span>
				</a>
			</div>

			<nav class="site-nav" aria-label="Primary">
				{% for item in site.nav %}
					{% set href = item.href if item.external else (item.href | relUrl(page.url)) %}
					<a
						href="{{ href }}"
						{% if item.external %}target="_blank" rel="noopener"{% endif %}
						{% if not item.external and (page.url == item.href or (item.href != "/" and page.url and page.url.startsWith(item.href))) %}aria-current="page"{% endif %}
					>{{ item.label }}</a>
				{% endfor %}
				<button type="button" class="theme-toggle" aria-label="Toggle color theme" aria-pressed="false" data-theme-toggle>
					<span class="theme-toggle__dot"></span>
				</button>
			</nav>
			</div>

			{% if playground %}
				<nav class="section-jump" aria-label="Playground sections">
					<a href="#playground">Input</a>
					<a href="#simulation">Simulation</a>
					<a href="#daltonize">Daltonize</a>
					<a href="#contrast">Contrast</a>
					<a href="#manipulate">Manipulate</a>
					<a href="#tint-shade">Tint / Shade</a>
					<a href="#blend">Blend</a>
					<a href="#harmonies">Harmonies</a>
					<a href="#scales">Scales</a>
					<a href="#naming">Naming</a>
					<a href="#temperature">Temperature</a>
					<a href="#palette">Palette</a>
					<a href="#delta-e">Delta E</a>
				</nav>
			{% endif %}
		</header>

		<main id="main" class="site-main">
			{{ content | safe }}
		</main>

		<footer class="site-footer">
			<div class="site-footer__rule"></div>
			<div class="site-footer__row">
				<span class="footer-mark">Swatch · v{{ site.version }} · Copyright © Raine Luntta · Licensed MIT</span>
				<span class="footer-meta">
					<a href="{{ site.repo }}" target="_blank" rel="noopener">GitHub</a>
					·
					<a href="{{ site.npm }}" target="_blank" rel="noopener">npm</a>
				</span>
			</div>
		</footer>

		<div id="toast" class="toast" role="status" aria-live="polite"></div>

		{% if playground %}
			<script type="module" src="{{ '/assets/js/playground/index.js' | relUrl(page.url) }}"></script>
		{% endif %}
		<script>
			// Copy buttons on code blocks. Progressive enhancement that runs on
			// every page — including reference pages, which don't load the
			// playground bundle.
			(function () {
				var toastEl = document.getElementById("toast");
				var toastTimer;
				function toast(msg) {
					if (!toastEl) return;
					toastEl.textContent = msg;
					toastEl.classList.add("is-visible");
					clearTimeout(toastTimer);
					toastTimer = setTimeout(function () {
						toastEl.classList.remove("is-visible");
					}, 1400);
				}
				function ready(fn) {
					if (document.readyState !== "loading") fn();
					else document.addEventListener("DOMContentLoaded", fn);
				}
				ready(function () {
					if (!navigator.clipboard) return;
					document.querySelectorAll(".site-main pre").forEach(function (pre) {
						var wrap = document.createElement("div");
						wrap.className = "code-block";
						pre.parentNode.insertBefore(wrap, pre);
						wrap.appendChild(pre);

						var btn = document.createElement("button");
						btn.type = "button";
						btn.className = "code-copy";
						btn.textContent = "Copy";
						btn.setAttribute("aria-label", "Copy code to clipboard");
						wrap.appendChild(btn);

						btn.addEventListener("click", function () {
							var code = pre.querySelector("code");
							var text = (code || pre).innerText;
							navigator.clipboard.writeText(text).then(
								function () {
									btn.textContent = "Copied";
									btn.dataset.copied = "true";
									toast("Copied to clipboard");
									setTimeout(function () {
										btn.textContent = "Copy";
										delete btn.dataset.copied;
									}, 1400);
								},
								function () {
									toast("Copy failed");
								}
							);
						});
					});
				});
			})();
		</script>
		<script>
			// Theme toggle
			var themeToggle = document.querySelector("[data-theme-toggle]");
			function syncThemeToggle() {
				if (themeToggle) {
					themeToggle.setAttribute(
						"aria-pressed",
						document.documentElement.dataset.theme === "dark" ? "true" : "false"
					);
				}
			}
			syncThemeToggle();
			themeToggle?.addEventListener("click", function () {
				var current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
				var next = current === "dark" ? "light" : "dark";
				document.documentElement.dataset.theme = next;
				syncThemeToggle();
				try { localStorage.setItem("swatch-theme", next); } catch (e) {}
			});
		</script>
	</body>
</html>
