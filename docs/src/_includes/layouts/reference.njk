---
layout: base.njk
---
<div class="reference-shell">
	<aside class="reference-side" aria-label="Reference navigation">
		<div class="reference-search" data-pagefind-ignore>
			<div id="search"></div>
		</div>
		<div class="reference-side__title">Reference</div>
		<ol>
			{% for item in collections.reference %}
				<li>
					<a href="{{ item.url | relUrl(page.url) }}"
						{% if page.url == item.url %}aria-current="page"{% endif %}>
						{{ item.data.title }}
					</a>
				</li>
			{% endfor %}
		</ol>
	</aside>

	<article class="reference-content" data-pagefind-body>
		{% if eyebrow %}<span class="reference-eyebrow">{{ eyebrow }}</span>{% endif %}
		<h1>{{ title }}</h1>
		{{ content | safe }}

		{% set ordered = collections.reference %}
		{% set prevItem = false %}
		{% set nextItem = false %}
		{% for item in ordered %}
			{% if item.url == page.url %}
				{% if loop.index0 > 0 %}{% set prevItem = ordered[loop.index0 - 1] %}{% endif %}
				{% if not loop.last %}{% set nextItem = ordered[loop.index0 + 1] %}{% endif %}
			{% endif %}
		{% endfor %}

		<nav class="reference-pager" aria-label="Pagination" data-pagefind-ignore>
			<div class="prev">
				{% if prevItem %}
					<a href="{{ prevItem.url | relUrl(page.url) }}">
						← Previous
						<strong>{{ prevItem.data.title }}</strong>
					</a>
				{% endif %}
			</div>
			<div class="next">
				{% if nextItem %}
					<a href="{{ nextItem.url | relUrl(page.url) }}">
						Next →
						<strong>{{ nextItem.data.title }}</strong>
					</a>
				{% endif %}
			</div>
		</nav>

		<footer class="reference-meta">
			{% set updated = page.inputPath | gitIsoDate %}
			{% if updated %}
				<span class="reference-meta__updated">
					Last updated <time datetime="{{ updated }}">{{ updated | humanDate }}</time>
				</span>
			{% endif %}
			<a
				class="reference-meta__edit"
				href="{{ site.repo }}/edit/master/{{ page.inputPath | repoPath }}"
				target="_blank"
				rel="noopener"
			>Edit this page on GitHub ↗</a>
		</footer>
	</article>
</div>

{# Pagefind search. The index lives at /pagefind/, generated by the production
   build (`npm run build`). It is absent during `npm run dev`, so the UI simply
   no-ops there. pagefind-ui.js auto-detects its bundle path relative to its own
   src, which keeps search working under the /swatch/ GitHub Pages subpath. #}
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" data-pagefind-ignore />
<script src="/pagefind/pagefind-ui.js" data-pagefind-ignore></script>
<script data-pagefind-ignore>
	window.addEventListener("DOMContentLoaded", function () {
		if (typeof PagefindUI === "undefined") return;
		new PagefindUI({
			element: "#search",
			showImages: false,
			showSubResults: true,
		});
	});
</script>
