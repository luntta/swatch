						<button class="btn btn--ghost" type="button" data-contrast-swap>Swap</button>
					</div>
				</div>
			</div>
		</t-contrast-panel>
	</section>

	{# ============================================================
	   Manipulate
	   ============================================================ #}
	<section class="section">
		<div class="section__head">
