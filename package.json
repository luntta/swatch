{
  "name": "tincturelib",
  "version": "2.0.0-alpha.1",
  "description": "A multi-purpose color library with first-class color blindness simulation.",
  "type": "module",
  "main": "./src/tincture.js",
  "module": "./src/tincture.js",
  "types": "./types/tincture.d.ts",
  "exports": {
    ".": {
      "types": "./types/tincture.d.ts",
      "import": "./src/tincture.js",
      "default": "./src/tincture.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luntta/tincture.git"
  },
  "author": "Raine Luntta",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luntta/tincture/issues"
  },
  "homepage": "https://github.com/luntta/tincture#readme"
}
