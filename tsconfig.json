{
	"compilerOptions": {
		"strict": true,
		"noEmit": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"swatch": ["./types/swatch.d.ts"]
		},
		"lib": ["ES2022"],
		"skipLibCheck": false,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["types/**/*.ts"]
}
